model User {
    id  String @id @default(uuid()) @db.Uuid
    name          String
    email         String   @unique
    password      String
    phone         String? 
    role          UserRole
    profileImage  String?
    status        UserStatus @default(ACTIVE)

    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt

    technicianProfile TechnicianProfile?
    booking Booking[]
    payment Payment[]
    review Review[]

}